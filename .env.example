# Обязательно: сгенерируйте свой секрет (32 hex-символа):
#   openssl rand -hex 16
SECRET=0123456789abcdef0123456789abcdef

# Опционально: тег для статистики (получить у @MTProxybot)
TAG=

# Количество воркеров (обычно = числу ядер CPU)
# Примечание: текущий docker-compose.yml использует host-networking и tune-опции
# напрямую в command, поэтому WORKERS здесь влияет только если вы вернётесь к
# запуску через start.sh. Оптимизация под LTE (BBR, буферы, MSS clamping)
# настраивается отдельно: scripts/sysctl-apply.sh и scripts/firewall-setup.sh.
WORKERS=1
